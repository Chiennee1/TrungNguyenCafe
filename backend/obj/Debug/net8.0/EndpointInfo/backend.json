  "components": {
    "schemas": {
      "AuditLog": {
        "required": [
          "sAction"
        ],
        "type": "object",
        "properties": {
          "logId": {
            "type": "string",
            "format": "uuid"
          },
          "tenantId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "userId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "sAction": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "sEntityName": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "sEntityId": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "sOldValue": {
            "type": "string",
            "nullable": true
          },
          "sNewValue": {
            "type": "string",
            "nullable": true
          },
          "sIpAddress": {
            "maxLength": 45,
            "type": "string",
            "nullable": true
          },
          "dCreatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "tenant": {
            "$ref": "#/components/schemas/Tenant"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        },
        "additionalProperties": false
      },
      "Category": {
        "required": [
          "sCategoryName"
        ],
        "type": "object",
        "properties": {
          "categoryId": {
            "type": "string",
            "format": "uuid"
          },
          "sCategoryName": {
            "maxLength": 80,
            "minLength": 1,
            "type": "string"
          },
          "sDescription": {
            "maxLength": 200,
            "type": "string",
            "nullable": true
          },
          "products": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Product"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateCustomerDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateOrderDto": {
        "required": [
          "items",
          "paymentMethod"
        ],
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "paymentMethod": {
            "minLength": 1,
            "type": "string"
          },
          "note": {
            "type": "string",
            "nullable": true
          },
          "items": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemDto"
            }
          }
        },
        "additionalProperties": false
      },
      "CreateProductDto": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "categoryId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "maxLength": 300,
            "type": "string",
            "nullable": true
          },
          "price": {
            "minimum": 0,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CreateUserDto": {
        "required": [
          "email",
          "fullName",
          "password",
          "roleId"
        ],
        "type": "object",
        "properties": {
          "roleId": {
            "type": "string",
            "format": "uuid"
          },
          "fullName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "maxLength": 50,
            "minLength": 6,
            "type": "string"
          },
          "phone": {
            "maxLength": 15,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Customer": {
        "required": [
          "sFullName",
          "sMemberLevel",
          "sPhone"
        ],
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "format": "uuid"
          },
          "sFullName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "sPhone": {
            "maxLength": 15,
            "minLength": 1,
            "type": "string"
          },
          "sEmail": {
            "maxLength": 150,
            "type": "string",
            "nullable": true
          },
          "iLoyaltyPoint": {
            "type": "integer",
            "format": "int32"
          },
          "sMemberLevel": {
            "maxLength": 10,
            "minLength": 1,
            "type": "string"
          },
          "dRegisteredAt": {
            "type": "string",
            "format": "date-time"
          },
          "orders": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Order"
            },
            "nullable": true
          },
          "loyaltyHistories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LoyaltyHistory"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
